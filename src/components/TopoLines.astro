---
interface Props {
  variant: 'home' | 'subpage';
}

const { variant } = Astro.props;
---

<div class="topo-lines" style={`opacity: ${variant === 'home' ? '0.06' : '0.05'}`}>
  {variant === 'home' ? (
    <svg viewBox="0 0 1200 800" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <path d="M0 600 Q200 550 400 580 Q600 610 800 560 Q1000 510 1200 540" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 500 Q150 460 350 490 Q550 520 750 470 Q950 420 1200 450" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 400 Q250 370 450 390 Q600 410 800 370 Q950 340 1200 360" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 320 Q200 280 400 310 Q550 330 750 290 Q900 260 1200 280" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 240 Q300 220 500 240 Q700 260 900 220 Q1050 200 1200 210" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 180 Q250 150 450 170 Q650 190 850 160 Q1000 140 1200 155" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
      <path d="M0 700 Q300 670 500 690 Q700 710 900 680 Q1100 650 1200 660" stroke="currentColor" stroke-width="1.5" fill="none" color="#7a9a7e"/>
    </svg>
  ) : (
    <svg viewBox="0 0 1200 600" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <path d="M0 450 Q200 420 400 440 Q600 460 800 430 Q1000 400 1200 420" stroke="#7a9a7e" stroke-width="1.5" fill="none"/>
      <path d="M0 370 Q150 340 350 360 Q550 380 750 350 Q950 320 1200 340" stroke="#7a9a7e" stroke-width="1.5" fill="none"/>
      <path d="M0 290 Q250 270 450 285 Q600 300 800 275 Q950 255 1200 270" stroke="#7a9a7e" stroke-width="1.5" fill="none"/>
      <path d="M0 220 Q200 195 400 215 Q550 230 750 205 Q900 185 1200 200" stroke="#7a9a7e" stroke-width="1.5" fill="none"/>
      <path d="M0 155 Q300 140 500 150 Q700 165 900 145 Q1050 130 1200 140" stroke="#7a9a7e" stroke-width="1.5" fill="none"/>
    </svg>
  )}
</div>

<style>
  .topo-lines {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .topo-lines svg {
    width: 100%;
    height: 100%;
  }
</style>
