---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import TopoLines from '../components/TopoLines.astro';
---

<BaseLayout
  title="Ridgeline Collaborative"
  description="Independent research and community building for Cascadia's energy future"
  ogImage="https://ridgelinecollab.org/og-home.png"
  ogUrl="https://ridgelinecollab.org"
>
  <Nav variant="home" />

  <section class="hero">
    <TopoLines variant="home" />

    <div class="hero-content">
      <div class="launch-badge">Launching 2026</div>
      <h1>Ridgeline <em>Collaborative</em></h1>
      <p class="hero-tagline">Independent research and community building for Cascadia's energy future.</p>
      <hr class="hero-rule">
      <a href="/reckoning" class="hero-cta">
        Read about our flagship paper
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <section class="about" id="about">
    <div class="section-inner">
      <div class="section-label">About</div>
      <h2 class="section-heading">Research and community for Cascadia's energy future</h2>
      <p class="about-text">
        <strong>Ridgeline Collaborative</strong> is an independent organization producing rigorous, accessible analysis of the Pacific Northwest's energy transition — and building community around the people doing the work. We translate the forces reshaping our electricity system into research that policymakers, advocates, and the public can act on, and we bring people together to figure out what comes next.
      </p>
    </div>
  </section>

  <section class="projects" id="projects">
    <div class="section-inner">
      <div class="section-label">Projects</div>
      <h2 class="section-heading">What we're working on</h2>

      <div class="project-grid">
        <div class="project-card primary">
          <div>
            <span class="project-status status-forthcoming">Paper forthcoming</span>
            <h3 class="project-title">PNW Energy Reckoning</h3>
            <p class="project-desc">A comprehensive analysis of three interlocking crises facing the Pacific Northwest electricity system — demand growth, institutional fragmentation, and the clean energy transition.</p>
            <a href="/reckoning" class="project-link">
              Learn more
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="project-visual">
            <svg width="280" height="200" viewBox="0 0 280 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 180 L40 140 L80 155 L120 100 L160 120 L200 60 L240 90 L280 50" stroke="#7a9a7e" stroke-width="2" fill="none"/>
              <path d="M0 180 L40 155 L80 165 L120 130 L160 145 L200 95 L240 115 L280 85" stroke="#7a9a7e" stroke-width="1.5" fill="none" opacity="0.6"/>
              <path d="M0 180 L40 165 L80 172 L120 150 L160 160 L200 125 L240 140 L280 115" stroke="#7a9a7e" stroke-width="1" fill="none" opacity="0.3"/>
            </svg>
          </div>
        </div>

        <div class="project-card">
          <span class="project-status status-forthcoming">July 2026</span>
          <h3 class="project-title">Climate & Change Camp</h3>
          <p class="project-desc">A four-day gathering at River Farm, 80 acres east of Bellingham. ~60 people working on climate and societal change &mdash; futures exercises, Cascadia-specific sessions, and time in the woods.</p>
          <a href="/camp" class="project-link secondary-link">
            Learn more
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="project-card">
          <span class="project-status status-soon">Coming soon</span>
          <h3 class="project-title">More forthcoming</h3>
          <p class="project-desc">Additional projects spanning preparedness, community resilience, and public understanding of complex systems.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="section-inner">
      <div class="section-label">Get in touch</div>
      <h2 class="section-heading">Let's connect</h2>
      <p class="contact-text">Interested in our work, have a question, or want to collaborate?</p>
      <a href="mailto:hello@ridgelinecollab.org" class="contact-email">hello@ridgelinecollab.org</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--forest);
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(122, 154, 126, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(61, 74, 92, 0.2) 0%, transparent 50%);
  }

  .hero-content {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
  }

  .launch-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--sage);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage-light);
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.8s ease both;
  }
  .launch-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 1.1;
    color: var(--warm-white);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s 0.15s ease both;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--sage-light);
  }

  .hero-tagline {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--slate-light);
    max-width: 560px;
    line-height: 1.7;
    font-weight: 300;
    animation: fadeInUp 0.8s 0.3s ease both;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    background: var(--sage);
    border: none;
    margin: 2.5rem 0;
    animation: fadeInUp 0.8s 0.45s ease both;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--gold-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s, gap 0.3s;
    animation: fadeInUp 0.8s 0.6s ease both;
  }
  .hero-cta:hover { color: var(--gold); gap: 0.75rem; }
  .hero-cta svg { transition: transform 0.3s; }
  .hero-cta:hover svg { transform: translateX(2px); }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: fadeInUp 0.8s 1s ease both;
  }
  .scroll-hint span {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--sage), transparent);
    animation: scrollPulse 2s infinite;
  }

  /* SECTIONS */
  section { padding: 6rem 2rem; }

  .section-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  /* Home page overrides section-heading to be larger */
  .section-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    margin-bottom: 1.5rem;
  }

  /* ABOUT */
  .about {
    background: var(--warm-white);
    border-bottom: 1px solid var(--border);
  }

  .about-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-light);
    max-width: 640px;
    font-weight: 300;
  }
  .about-text strong {
    color: var(--text);
    font-weight: 500;
  }

  /* PROJECTS */
  .projects { background: var(--cream); }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .project-card {
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 2.5rem;
    transition: border-color 0.3s, transform 0.3s;
    position: relative;
  }
  .project-card:hover {
    border-color: var(--sage);
    transform: translateY(-2px);
  }
  .project-card.primary {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    background: var(--forest);
    border-color: var(--forest);
    color: var(--warm-white);
  }
  .project-card.primary:hover {
    border-color: var(--sage);
  }

  .project-status {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }
  .status-forthcoming {
    background: rgba(196, 163, 90, 0.15);
    color: var(--gold);
  }
  .primary .status-forthcoming {
    background: rgba(196, 163, 90, 0.2);
  }
  .status-soon {
    background: rgba(122, 154, 126, 0.15);
    color: var(--sage);
  }

  .project-title {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }
  .primary .project-title { font-size: 1.8rem; }

  .project-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-light);
    font-weight: 300;
  }
  .primary .project-desc { color: var(--sage-light); }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: gap 0.3s;
  }
  .primary .project-link { color: var(--gold-muted); }
  .secondary-link { color: var(--sage); }
  .project-link:hover { gap: 0.65rem; }

  /* Stretched link */
  .project-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .project-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.12;
  }

  /* CONTACT */
  .contact {
    background: var(--warm-white);
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 5rem 2rem;
  }
  .contact .section-label { margin-bottom: 1rem; }
  .contact .section-heading { margin-bottom: 1rem; }
  .contact-text {
    color: var(--text-light);
    font-weight: 300;
    margin-bottom: 2rem;
  }
  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    color: var(--forest);
    text-decoration: none;
    border-bottom: 1px solid var(--sage-light);
    padding-bottom: 0.2rem;
    transition: border-color 0.3s, color 0.3s;
  }
  .contact-email:hover {
    color: var(--forest-mid);
    border-color: var(--forest);
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .hero { padding: 5rem 1.5rem 4rem; }
    .project-grid { grid-template-columns: 1fr; }
    .project-card.primary { grid-template-columns: 1fr; }
    .project-visual { display: none; }
  }

  @media (max-width: 480px) {
    .hero h1 { font-size: 2.2rem; }
    .project-card { padding: 1.75rem; }
  }
</style>
